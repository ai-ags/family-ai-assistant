// This is a Prisma schema file for the Family AI Assistant

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// User model
model User {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  name        String?
  password    String
  families     Family[]
  chats       Chat[]
  todos       Todo[]
  digests     Digest[]
  notebooks   Notebook[]
  foods       Food[]
}

// Family model
model Family {
  id    Int    @id @default(autoincrement())
  name  String
  users User[]
}

// AI model
model AI {
  id      Int    @id @default(autoincrement())
  name    String
  family  Family?
}

// Chat module
model Chat {
  id       Int     @id @default(autoincrement())
  content  String
  user     User    @relation(fields: [userId], references: [id])
  userId   Int
}

// Todo module
model Todo {
  id       Int     @id @default(autoincrement())
  title    String
  completed Boolean @default(false)
  user     User    @relation(fields: [userId], references: [id])
  userId   Int
}

// Digest module
model Digest {
  id      Int     @id @default(autoincrement())
  entry   String
  user    User     @relation(fields: [userId], references: [id])
  userId  Int
}

// Storage module
model Storage {
  id       Int     @id @default(autoincrement())
  fileName String
  fileSize Int
  user     User    @relation(fields: [userId], references: [id])
  userId   Int
}

// Notebook module
model Notebook {
  id       Int     @id @default(autoincrement())
  title    String
  content  String
  user     User    @relation(fields: [userId], references: [id])
  userId   Int
}

// Food module
model Food {
  id       Int     @id @default(autoincrement())
  name     String
  calories  Int
  user     User    @relation(fields: [userId], references: [id])
  userId   Int
}